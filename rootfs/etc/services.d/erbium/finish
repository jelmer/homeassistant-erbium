#!/usr/bin/with-contenv bashio

EXIT_CODE="${1}"

# If exit code is not 0 and not 256 (intentional stop), shutdown s6
if [ "${EXIT_CODE}" -ne 0 ] && [ "${EXIT_CODE}" -ne 256 ]; then
    bashio::log.warning "Erbium exited with code ${EXIT_CODE}, shutting down addon"
    s6-svscanctl -t /var/run/s6/services
fi
